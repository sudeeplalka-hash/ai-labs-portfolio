# Governance runs fully client-side by default (in-browser engine, no backend).
NEXT_PUBLIC_STATIC_DEMO=1

# Optional: to use the real FastAPI governance service (services/governance-api)
# instead of the in-browser engine, set:
#   NEXT_PUBLIC_STATIC_DEMO=0
#   NEXT_PUBLIC_API_URL=https://your-governance-api.example.com
